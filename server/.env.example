# Environment Configuration — IEEE Finance Pro Server

# MongoDB
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/ieee-finance?retryWrites=true&w=majority

# Server
PORT=5000
NODE_ENV=development

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-me-in-production
JWT_EXPIRY=7d
JWT_REFRESH_SECRET=your-refresh-secret-change-me-in-production
JWT_REFRESH_EXPIRY=30d

# Google Drive (Phase 7)
# GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./credentials/service-account.json
# GOOGLE_DRIVE_ROOT_FOLDER_ID=your-drive-folder-id
